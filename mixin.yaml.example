_custom:
  system-proxy:
    enable: true

mixed-port: 7890

external-controller: "0.0.0.0:9090"
external-ui: dist
external-ui-url: https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip
secret:

allow-lan: true # 允许局域网/容器访问 mixed-port，需配 authentication 才安全
authentication:
  - "sub2api:REPLACE_WITH_PROXY_PASS" # 用户验证（clashon 会自动填充）

# prefix：前置插入
# suffix：后置插入
# override：根据 name 匹配并替换原项
# inject (仅 proxy-groups)：按 name 匹配，把指定 proxy 追加到已有 group 的 .proxies 列表（自动去重）
rules:
  prefix:
    - DOMAIN,api64.ipify.org,DIRECT # 用于 clashui 获取真实公网 IP
    # - DOMAIN-KEYWORD,github,proxy   # 用于 clashupgrade 升级内核

    # ===== AI 服务强制走 JP/US =====
    - DOMAIN-SUFFIX,anthropic.com,🤖 AI 优选
    - DOMAIN-SUFFIX,claude.ai,🤖 AI 优选
    - DOMAIN-KEYWORD,claude,🤖 AI 优选
    - DOMAIN-SUFFIX,openai.com,🤖 AI 优选
    - DOMAIN-SUFFIX,chatgpt.com,🤖 AI 优选
    - DOMAIN-SUFFIX,oaistatic.com,🤖 AI 优选
    - DOMAIN-SUFFIX,oaiusercontent.com,🤖 AI 优选
    - DOMAIN-KEYWORD,openai,🤖 AI 优选
    - DOMAIN-KEYWORD,chatgpt,🤖 AI 优选
    - DOMAIN-SUFFIX,gemini.google.com,🤖 AI 优选
    - DOMAIN-SUFFIX,bard.google.com,🤖 AI 优选
    - DOMAIN-SUFFIX,generativelanguage.googleapis.com,🤖 AI 优选
  suffix:
    # ===== 兜底：所有未命中规则的流量都走 JP/US =====
    - MATCH,🌐 全局出口

# 第二订阅作为节点池注入；mihomo 会自动定时刷新（24h 由订阅头部 profile-update-interval 控制，
# 这里用 interval 强制每小时拉一次，确保失效节点能尽快剔除）
proxy-providers:
  smjc:
    type: http
    url: "https://YOUR-SUB2-PROVIDER/api/v1/client/subscribe?token=YOUR-SUB2-TOKEN"
    path: ./providers/smjc.yaml
    interval: 3600
    header:
      User-Agent:
        - "clash-verge/v2.4.0"
    health-check:
      enable: true
      url: https://www.gstatic.com/generate_204
      interval: 300
      lazy: true
    # 排除明显的"信息节点"（流量、到期等占位项），避免被 include-all 拉进 JP/US 组
    exclude-filter: "(?i)流量|过期|到期|官网|邮件|节点|订阅|重置|套餐|注意|发送|获取|不推荐"

proxies:
  prefix:
  suffix:
  override:

proxy-groups:
  # 把订阅自带的 "SDK DNS"（订阅 MATCH 默认指向它）改为指向我们的全局出口，
  # 确保所有未命中规则的流量都走 JP/US。
  override:
    - name: SDK DNS
      type: select
      proxies:
        - 🌐 全局出口
        - 🇯🇵 日本节点
        - 🇺🇸 美国节点
        - 🇯🇵 日本-订阅1
        - 🇯🇵 日本-订阅2
        - 🇺🇸 美国-订阅1
        - 🇺🇸 美国-订阅2
        - DIRECT
  prefix:
    # AI 优选：fallback 组，美国整体不可用才掉到日本
    # - 优先走"美国节点"组（内部 url-test 已自动选最快的美国节点，
    #   单个美国节点延迟波动 50ms+ 会在该组内自动切换，不跨国跳）
    # - 当美国节点组所有节点都连不通时，才切到"日本节点"组
    # - 日本也不可用时，直连兜底（避免完全不通）
    # 注意：mihomo fallback 基于"可达性"判定，不支持"延迟阈值"。
    # "美国延迟过高就切日本"等价于"美国节点组里没有任何延迟可接受的节点"，
    # 实际由 url-test 在组内部完成节点选择，fallback 只负责整组级别的切换。
    - name: 🤖 AI 优选
      type: fallback
      url: https://www.gstatic.com/generate_204
      interval: 60
      timeout: 5000
      proxies:
        - 🇺🇸 美国节点
        - 🇯🇵 日本节点
        - DIRECT

    # 总出口：默认走"日本节点（合并）"组，可在面板手动切换
    - name: 🌐 全局出口
      type: select
      proxies:
        - 🤖 AI 优选
        - 🇯🇵 日本节点
        - 🇺🇸 美国节点
        - 🇯🇵 日本-订阅1
        - 🇯🇵 日本-订阅2
        - 🇺🇸 美国-订阅1
        - 🇺🇸 美国-订阅2

    # 日本节点合并组（来自所有订阅的日本节点，自动选最快）
    - name: 🇯🇵 日本节点
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      use-existing-proxies: true
      include-all: true
      filter: "(?i)日本|jp\\b|japan|tokyo|osaka|🇯🇵"

    # 美国节点合并组（来自所有订阅的美国节点，自动选最快）
    - name: 🇺🇸 美国节点
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      use-existing-proxies: true
      include-all: true
      filter: "(?i)美国|us\\b|usa|united states|america|los angeles|seattle|san jose|silicon|kansas|🇺🇸"

    # 仅订阅1（次元/sdkdns）的日本节点
    - name: 🇯🇵 日本-订阅1
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      include-all-proxies: true
      filter: "(?i)日本|jp\\b|japan|tokyo|osaka|🇯🇵"

    # 仅订阅2（smjc）的日本节点
    - name: 🇯🇵 日本-订阅2
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      use:
        - smjc
      filter: "(?i)日本|jp\\b|japan|tokyo|osaka|🇯🇵"

    # 仅订阅1 的美国节点
    - name: 🇺🇸 美国-订阅1
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      include-all-proxies: true
      filter: "(?i)美国|us\\b|usa|united states|america|los angeles|seattle|san jose|silicon|🇺🇸"

    # 仅订阅2 的美国节点
    - name: 🇺🇸 美国-订阅2
      type: url-test
      url: https://www.gstatic.com/generate_204
      interval: 300
      tolerance: 50
      use:
        - smjc
      filter: "(?i)美国|us\\b|usa|united states|america|los angeles|seattle|san jose|silicon|kansas|堪萨斯|🇺🇸"
  suffix:
  # inject 示例：把自定义的 "我的链式代理" 注入到订阅的 "♻️ 手动切换" 组里
  # 这样无需 override 整组就能在 dashboard 上选中它
  # inject:
  #   "♻️ 手动切换":
  #     - "我的链式代理"

# tun 配置
tun:
  enable: true
  stack: system
  auto-route: true
  auto-redir: true # clash
  auto-redirect: true # mihomo
  auto-detect-interface: true
  dns-hijack:
    - any:53
    - tcp://any:53
  strict-route: true
  route-exclude-address:
    - 1.1.1.1/32 # 用于 clashui 获取真实内网 IP
    - 127.0.0.1/32
  exclude-interface:
    - docker0 # 避免无法访问容器内服务
    - podman0 # 详见：https://github.com/nelvko/clash-for-linux-install/issues/100#issuecomment-2995667368

# DNS 配置
dns:
  enable: true
  listen: 0.0.0.0:1053
  enhanced-mode: fake-ip
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  # 避免在启用 Tun + dns-hijack 时将代理节点域名解析为 fake-ip。
  proxy-server-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 1.1.1.1
    - 8.8.8.8
  nameserver:
    - 114.114.114.114
    - 8.8.8.8

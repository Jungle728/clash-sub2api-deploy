# sub2api 环境变量模板
#
# 用法：
#   cp .env.example .env
#   chmod 600 .env
#   # 用 openssl 生成 3 个 32 字节 hex 密钥，分别替换下面的占位符
#   for k in POSTGRES_PASSWORD JWT_SECRET TOTP_ENCRYPTION_KEY; do
#     val=$(openssl rand -hex 32)
#     sed -i "s|^${k}=.*|${k}=${val}|" .env
#   done
#
# 完整字段说明见 https://github.com/Wei-Shaw/sub2api/blob/main/deploy/.env.example

# ==== 必须 ====
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD   # openssl rand -hex 32
POSTGRES_DB=sub2api

# ==== JWT / TOTP 加密密钥（务必固定，否则重启后所有用户被踢，2FA 失效） ====
JWT_SECRET=REPLACE_WITH_JWT_SECRET                  # openssl rand -hex 32
TOTP_ENCRYPTION_KEY=REPLACE_WITH_TOTP_KEY           # openssl rand -hex 32

# ==== 管理员账号（首启自动建） ====
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=                                      # 留空 = 首启日志输出一次性随机密码（推荐）

# ==== 服务参数 ====
SERVER_PORT=8080
TZ=Asia/Shanghai
SERVER_MODE=release
RUN_MODE=standard

# ==== 容器走代理 ====
# 由 docker-compose.override.yml 注入 HTTP_PROXY / HTTPS_PROXY 即可，无需在此配
# 但 sub2api 自己的 GitHub 升级接口可独立配代理：
UPDATE_PROXY_URL=                                    # 例如 http://user:pass@host.docker.internal:7890

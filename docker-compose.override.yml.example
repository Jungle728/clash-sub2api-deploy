# Resource limits and operational defaults for a small sub2api host.
# Account proxies are configured in the sub2api UI/database, not as
# container-level HTTP_PROXY or HTTPS_PROXY environment variables.

x-low-memory-logging: &low-memory-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "3"

services:
  sub2api:
    mem_limit: 384m
    logging: *low-memory-logging
    environment:
      - GATEWAY_OPENAI_WS_STICKY_SESSION_TTL_SECONDS=86400
      - GATEWAY_OPENAI_WS_STICKY_RESPONSE_ID_TTL_SECONDS=86400
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  postgres:
    mem_limit: 256m
    logging: *low-memory-logging
    command:
      - postgres
      - -c
      - max_connections=30
      - -c
      - shared_buffers=64MB
      - -c
      - work_mem=2MB
      - -c
      - maintenance_work_mem=32MB
      - -c
      - effective_cache_size=256MB
      - -c
      - wal_buffers=4MB
      - -c
      - max_wal_size=256MB

  redis:
    mem_limit: 128m
    logging: *low-memory-logging
    environment:
      - REDIS_PASSWORD=${REDIS_PASSWORD:-}
    command: >
      sh -c '
        redis-server
        --save 60 1
        --appendonly yes
        --appendfsync everysec
        --maxmemory 96mb
        --maxmemory-policy allkeys-lru
        $${REDIS_PASSWORD:+--requirepass "$$REDIS_PASSWORD"}'
